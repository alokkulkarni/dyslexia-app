# =============================================================================
# DyslexiLearn App — Root .gitignore
# =============================================================================

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Icon?

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ── Environment variables (NEVER commit secrets) ──────────────────────────────
.env
.env.*
!.env.example
!.env.test
*.local

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
*.tsbuildinfo

# ── Vite ──────────────────────────────────────────────────────────────────────
.vite/

# ── AWS SAM build artifacts ───────────────────────────────────────────────────
# .aws-sam/build contains absolute local paths — never commit
.aws-sam/
# samconfig.toml can contain account-specific deployment config
samconfig.toml

# ── AWS credentials and private keys (NEVER commit) ──────────────────────────
.aws/
*.pem
*.key
*.p12
*.pfx
*_rsa
*_ed25519
credentials

# ── Python (aws_diagram.py, any utility scripts) ──────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.venv/
venv/
env/
.Python
pip-log.txt
.tox/
.pytest_cache/
*.egg-info/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── IDE and editor directories ────────────────────────────────────────────────
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~
.project
.classpath
.settings/
# VS Code: ignore user settings but keep shared project config
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ── Test and coverage outputs ─────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
playwright/.cache/

# ── Temporary and misc ────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej
.cache/
.parcel-cache/

# ── Terraform (if ever used alongside SAM) ────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
