---
title: "Agent Skills — Discovery, Activation, and Execution"
---
%%{init: {'theme': 'base', 'themeVariables': {'fontSize': '13px', 'fontFamily': 'monospace'}}}%%
graph TD
    subgraph SKILLS["agentskills.io Open Standard  (SKILL.md)"]
        direction LR
        SK1[".claude/skills/sdlc-analyse/SKILL.md"]
        SK2[".claude/skills/sdlc-architecture/SKILL.md"]
        SK3[".claude/skills/sdlc-backlog/SKILL.md"]
        SK4[".claude/skills/sdlc-codegen/SKILL.md"]
        SK5[".claude/skills/sdlc-test/SKILL.md"]
        SK6[".claude/skills/sdlc-review/SKILL.md\n(disable-model-invocation: true)"]
        SK7[".claude/skills/sdlc-full/SKILL.md\n(disable-model-invocation: true)"]
    end

    subgraph DISC["Stage 1 — Discovery  (at startup)"]
        D1["Agent reads name + description only\n(low context cost)\nBuilds intent-to-skill map"]
    end

    subgraph CC["Claude Code"]
        CC1["Reads .claude/skills/ at startup"]
        CC2["Slash commands\n/sdlc-analyse  /sdlc-review  /sdlc-full"]
        CC3["Auto-invokes on description match\n(unless disable-model-invocation: true)"]
    end

    subgraph CP["GitHub Copilot"]
        CP1["Reads .claude/skills/ at startup\n(also .github/skills/, .agents/skills/)"]
        CP2["Agent mode  (VSCode / IntelliJ)\ngh copilot CLI"]
        CP3["SKILL.md injected when Copilot\nchooses skill as relevant"]
    end

    subgraph ACT["Stage 2 — Activation  (on match)"]
        A1["Full SKILL.md injected into context\nDynamic context via command blocks\nArguments substituted via ARGUMENTS"]
    end

    subgraph EXEC["Stage 3 — Execution"]
        E1["Agent follows SKILL.md instructions\nCalls sdlc_run MCP tool"]
    end

    subgraph BRIDGE["AgentCore Bridge MCP Server"]
        B1["sdlc_run(phase, input, project_key, repo)\nInvokeAgentCommand → AgentCore"]
    end

    subgraph AGENTCORE["AgentCore  (Amazon Bedrock)"]
        direction LR
        ORC["SDLC Orchestrator"]
        AG1["Analysis Agent"]
        AG2["Architecture Agent"]
        AG3["Refinement Agent"]
        AG4["Code Gen Agent"]
        AG5["Test Agent"]
        AG6["Review Agent"]
    end

    SKILLS -- "loaded at startup" --> DISC
    DISC --> CC1
    DISC --> CP1
    CC1 --> CC2
    CC1 --> CC3
    CP1 --> CP2
    CP1 --> CP3
    CC2 -- "developer invokes" --> ACT
    CC3 -- "auto-activates" --> ACT
    CP2 -- "developer invokes" --> ACT
    CP3 -- "auto-activates" --> ACT
    ACT --> EXEC
    EXEC -- "MCP protocol  (stdio or SSE)" --> B1
    B1 -- "InvokeAgentCommand" --> ORC
    ORC -- "delegates by phase" --> AG1
    ORC --> AG2
    ORC --> AG3
    ORC --> AG4
    ORC --> AG5
    ORC --> AG6

    classDef skills   fill:#1a2a1a,color:#e0e0e0,stroke:#53c28b,stroke-width:1px
    classDef stage    fill:#1a1a2e,color:#e0e0e0,stroke:#4a9eff,stroke-width:1px
    classDef cc       fill:#1a1a2e,color:#e0e0e0,stroke:#4a9eff,stroke-width:1px
    classDef cp       fill:#1a1a2e,color:#e0e0e0,stroke:#9b59b6,stroke-width:1px
    classDef bridge   fill:#2e1a1a,color:#e0e0e0,stroke:#e74c3c,stroke-width:1px
    classDef core     fill:#0f3460,color:#e0e0e0,stroke:#53c28b,stroke-width:1px

    class SK1,SK2,SK3,SK4,SK5,SK6,SK7 skills
    class D1,A1,E1 stage
    class CC1,CC2,CC3 cc
    class CP1,CP2,CP3 cp
    class B1 bridge
    class ORC,AG1,AG2,AG3,AG4,AG5,AG6 core
